{
  "name": "nyuchi-docs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for nyuchi-docs site, nyuchi-docs-search package, and shamwari-docs-ai worker.",
  "scripts": {
    "dev": "pnpm --filter site dev",
    "build": "pnpm --filter site build",
    "build:all": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "deploy:worker": "pnpm --filter shamwari-docs-ai deploy",
    "ingest": "pnpm --filter shamwari-docs-ai ingest",
    "deploy:mcp": "pnpm --filter nyuchi-docs-mcp-worker deploy"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "astro@<6.4.6": ">=6.4.6 <7",
      "cookie@<0.7.0": ">=0.7.0",
      "esbuild@<0.25.0": ">=0.25.0",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "svgo@>=4.0.0 <4.0.2": ">=4.0.2",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0",
      "vite@<6.4.2": ">=6.4.2",
      "vite@>=7.0.0 <7.3.5": ">=7.3.5 <8",
      "vitest@<3.2.6": ">=3.2.6",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0"
    }
  }
}
