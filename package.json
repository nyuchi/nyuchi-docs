{
  "name": "nyuchi-docs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for nyuchi-docs site, nyuchi-docs-search package, and shamwari-docs-ai worker.",
  "scripts": {
    "dev": "pnpm --filter site dev",
    "build": "pnpm --filter site build",
    "build:all": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "deploy:worker": "pnpm --filter shamwari-docs-ai deploy",
    "ingest": "pnpm --filter shamwari-docs-ai ingest"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
