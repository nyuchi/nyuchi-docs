{
  "name": "nyuchi-docs-search",
  "version": "0.1.0",
  "description": "Mintlify-style cmdk search modal with Pagefind + Ask-AI for Starlight docs sites (nyuchi-docs, bundu-docs).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyuchi/nyuchi-docs.git",
    "directory": "nyuchi-docs-search"
  },
  "keywords": [
    "starlight",
    "astro",
    "search",
    "cmdk",
    "pagefind",
    "docs"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./SearchModal.svelte": {
      "types": "./dist/SearchModal.svelte.d.ts",
      "svelte": "./dist/SearchModal.svelte"
    },
    "./Search.astro": "./dist/Search.astro"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "svelte-package -i src -o dist && publint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@astrojs/starlight": "^0.39.0",
    "svelte": "^5.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@sveltejs/kit": "^2.7.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/svelte": "^5.2.4",
    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^25.0.1",
    "publint": "^0.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.4"
  }
}
